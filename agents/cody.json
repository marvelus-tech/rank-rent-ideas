      "build_required": true,
      "mobile_first": true,
      "content_separation": true,
      "anti_ai_slop": true
    },
    "video": {
      "location": "~/.openclaw/workspace/videos/YYYY-MM-DD-{topic}/",
      "render_required": true,
      "frame_review": true,
      "quality_check": true
    }
  },
  "handoff": {
    "report_paths": true,
    "describe_design_elements": true,
    "include_deploy_instructions": true,
    "suggest_next_steps": true,
    "include_screenshot": true
  }
