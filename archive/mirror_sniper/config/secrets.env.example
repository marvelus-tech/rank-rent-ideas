# MirrorSniper secret environment variables
# Copy to .env or config/secrets.env and fill values

MIRROR_DATABASE_URL=sqlite+aiosqlite:///./mirror_sniper.db
MIRROR_SOLANA_PRIVATE_KEY=
MIRROR_SOLANA_PUBLIC_KEY=
MIRROR_HELIUS_API_KEY=
MIRROR_TELEGRAM_BOT_TOKEN= 
MIRROR_TELEGRAM_CHAT_ID=

# Required for Phase 4 (Live Trading)
TRADING_WALLET_PRIVATE_KEY=your_base58_private_key_here

# Optional: Additional RPC endpoint
QUICKNODE_RPC_URL=https://...
