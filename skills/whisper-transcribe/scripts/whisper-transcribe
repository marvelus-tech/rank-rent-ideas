#!/bin/bash
# whisper-transcribe - Skill wrapper for OpenAI Whisper
# Transcribes audio/video files to text using local AI

set -e

# Default settings
MODEL="base"
LANGUAGE="auto"
FORMAT="all"
OUTPUT_DIR="/Users/oktos/.openclaw/workspace/transcripts"

# Parse arguments
FILE=""
while [[ $# -gt 0 ]]; do
    case $1 in
        --model)
            MODEL="$2"
            shift 2
            ;;
        --language)
            LANGUAGE="$2"
            shift 2
            ;;
        --format)
            FORMAT="$2"
            shift 2
            ;;
        --output)
            OUTPUT_DIR="$2"
            shift 2
            ;;
        --help)
            echo "Usage: whisper-transcribe <file> [options]"
            echo ""
            echo "Options:"
            echo "  --model tiny|base|small|medium|large  Model size (default: base)"
            echo "  --language auto|en|es|...              Language (default: auto)"
            echo "  --format txt|json|srt|vtt|tsv|all      Output format (default: all)"
            echo "  --output <dir>                         Output directory"
            echo "  --help                                 Show this help"
            echo ""
            echo "Examples:"
            echo "  whisper-transcribe audio.mp3"
            echo "  whisper-transcribe video.mp4 --format srt"
            echo "  whisper-transcribe podcast.mp3 --model small --output ./texts/"
            exit 0
            ;;
        -*)
            echo "Unknown option: $1"
            echo "Use --help for usage information"
            exit 1
            ;;
        *)
            if [ -z "$FILE" ]; then
                FILE="$1"
            else
                echo "Error: Only one file at a time"
                exit 1
            fi
            shift
            ;;
    esac
done

# Validate file
if [ -z "$FILE" ]; then
    echo "Error: No input file specified"
    echo "Usage: whisper-transcribe <file> [options]"
    exit 1
fi

if [ ! -f "$FILE" ]; then
    echo "Error: File not found: $FILE"
    exit 1
fi

# Create output directory
mkdir -p "$OUTPUT_DIR"

# Build whisper command
CMD="whisper \"$FILE\" --model $MODEL --output_dir \"$OUTPUT_DIR\""

if [ "$LANGUAGE" != "auto" ]; then
    CMD="$CMD --language $LANGUAGE"
fi

if [ "$FORMAT" != "all" ]; then
    CMD="$CMD --output_format $FORMAT"
else
    # Whisper default outputs multiple formats, just let it do its thing
    CMD="$CMD"
fi

echo "=========================================="
echo "Transcribing: $(basename "$FILE")"
echo "Model: $MODEL"
echo "Language: $LANGUAGE"
echo "Output: $OUTPUT_DIR"
echo "=========================================="
echo ""

# Run whisper
eval $CMD

echo ""
echo "=========================================="
echo "Transcription complete!"
echo "Output directory: $OUTPUT_DIR"
echo "=========================================="

# List output files
echo ""
echo "Generated files:"
ls -lh "$OUTPUT_DIR"/*"$(basename "$FILE" | sed 's/\.[^.]*$//')"* 2>/dev/null || ls -lh "$OUTPUT_DIR"/
